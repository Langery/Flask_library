# Flask_library 环境变量示例
# 复制为 .env 后填值,docker-compose 会自动读取
# 注意:.env 不要 commit 到 git(已在 .gitignore)

# 必填:JWT 签名密钥。生产用 openssl rand -hex 32 生成
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# 跨域白名单,逗号分隔。生产改成真实前端域名
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 日志:text(人类可读) / json(机器解析,Loki/ES 友好)
LOG_FORMAT=text
LOG_LEVEL=INFO

# Rate limit 存储:memory://(开发) / redis://...:6379/0(生产)
RATELIMIT_STORAGE_URI=memory://
